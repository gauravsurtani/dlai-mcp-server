            {
              "title": "Who should join?",
              "body": "<p><strong>ChatGPT Prompt Engineering for Developers</strong> is beginner-friendly. Only a basic understanding of Python is needed. But it is also suitable for advanced machine learning engineers wanting to approach the cutting-edge of prompt engineering and use LLMs.</p>\n<div style=\"all: initial;\">\n<div style=\"position: fixed; z-index: 2147483647; inset: 16px; pointer-events: none; font-family: sans-serif;\"></div>\n</div>\n<div style=\"all: initial;\">\n<div style=\"position: fixed; z-index: 2147483647; inset: 16px; pointer-events: none; font-family: sans-serif;\"></div>\n</div>\n<div style=\"all: initial;\">\n<div style=\"position: fixed; z-index: 2147483647; inset: 16px; pointer-events: none; font-family: sans-serif;\"></div>\n</div>\n<div class=\"pixiebrix-notifier-container\" style=\"all: initial;\">\n<div style=\"position: fixed; z-index: 2147483647; inset: 16px; pointer-events: none; font-family: sans-serif;\"></div>\n</div>\n<div class=\"pixiebrix-notifier-container\" style=\"all: initial;\">\n<div style=\"position: fixed; z-index: 2147483647; inset: 16px; pointer-events: none; font-family: sans-serif;\"></div>\n</div>\n",
              "styles": {
                "section": "section--default",
